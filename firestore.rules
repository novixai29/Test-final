rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'musen.almajidi.alallaf@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUserProfile(data) {
      return data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.subscription in ['free', 'paid'] &&
             data.freeUploadsUsed is number && data.freeUploadsUsed >= 0 &&
             data.level in ['Beginner', 'Intermediate', 'Advanced'] &&
             data.dialect is string && data.dialect.size() > 0 && data.dialect.size() < 50 &&
             (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100));
    }

    function isValidPastLecture(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.summary is string && data.summary.size() >= 0 && data.summary.size() < 10000 &&
             data.date is number;
    }

    function isValidFeedback(data) {
      return data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.lectureTitle is string && data.lectureTitle.size() > 0 && data.lectureTitle.size() < 500 &&
             data.type in ['up', 'down'] &&
             data.createdAt is timestamp &&
             (!('comment' in data) || (data.comment is string && data.comment.size() < 5000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /public_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(profileId) && 
        request.resource.data.keys().hasAll(['uid', 'displayName', 'level']) &&
        request.resource.data.uid == profileId &&
        request.resource.data.displayName is string && request.resource.data.displayName.size() < 100 &&
        request.resource.data.level in ['Beginner', 'Intermediate', 'Advanced'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && hasRequiredFields(['uid', 'subscription', 'freeUploadsUsed', 'level', 'dialect']) && isValidUserProfile(request.resource.data) && uidUnchanged();
      allow update: if (isOwner(userId) && isValidUserProfile(request.resource.data) && uidNotModified()) || isAdmin();
      
      match /lectures/{lectureId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && hasRequiredFields(['id', 'uid', 'title', 'summary', 'date']) && isValidPastLecture(request.resource.data) && uidUnchanged();
        allow update: if isOwner(userId) && isValidPastLecture(request.resource.data) && uidNotModified();
        allow delete: if isOwner(userId);
      }
    }

    match /admins/{adminEmail} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /feedbacks/{feedbackId} {
      allow read: if isAdmin(); // only admin can read all feedbacks
      allow create: if hasRequiredFields(['userId', 'lectureTitle', 'type', 'createdAt']) && isValidFeedback(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
